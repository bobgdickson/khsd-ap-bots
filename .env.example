# Database connection strings and credentials
DATABASE_URL="mssql+pyodbc://user:pass@host/db?driver=ODBC+Driver+17+for+SQL+Server"
PS_DB_URL="mssql+pyodbc://user:pass@host/db?driver=ODBC+Driver+17+for+SQL+Server"
PS_DB_URL_HCM="mssql+pyodbc://user:pass@host/db?driver=ODBC+Driver+17+for+SQL+Server"
PASSPHRASE="your_passphrase_here"

# PeopleSoft credentials and URLs
PEOPLESOFT_USERNAME=user@whatever.org
PEOPLESOFT_PASSWORD=password123
PEOPLESOFT_ENV=https://peoplesoft_prod_url/
PEOPLESOFT_TEST_ENV=https://peoplesoft_test_url/
PEOPLESOFT_ENV_HCM=https://peoplesoft_prod_url/
PEOPLESOFT_TEST_ENV_HCM=https://peoplesoft_test_url/

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# If using local OCR installation, otherwise use multimodal LLM vision
TESSERACT_CMD=C:\Users\<YOUR_USER>\AppData\Local\Programs\Tesseract-OCR\tesseract.exe
TESSDATA_PREFIX=C:\Users\<YOUR_USER>\AppData\Local\Programs\Tesseract-OCR\tessdata

# Set to 1 to run bots locally, 0 to prevent running in environments where not desired
RUN_BOTS_LOCALLY=0

# Entra ID (Azure AD) configuration for API token validation
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Optional: if you expose a custom API URI/scope in Entra, include it here.
# Example: api://00000000-0000-0000-0000-000000000000
AZURE_API_URI=

# Comma-separated list of allowed frontend origins for CORS
FRONTEND_ORIGINS=http://localhost:3000

# Langfuse configuration
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASE_URL="https://cloud.langfuse.com" 
