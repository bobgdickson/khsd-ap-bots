NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Microsoft Entra configuration
NEXT_PUBLIC_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Optional custom redirect URIs; defaults are based on window.location.origin
NEXT_PUBLIC_ENTRA_REDIRECT_PATH=/auth/v2/login
NEXT_PUBLIC_ENTRA_POST_LOGOUT_REDIRECT_PATH=/auth/v2/login
# Enable verbose auth debugging in Next.js terminal + browser console
NEXT_PUBLIC_AUTH_DEBUG=0
# Scope exposed by your API app registration. Example:
# api://00000000-0000-0000-0000-000000000000/access_as_user
NEXT_PUBLIC_ENTRA_API_SCOPE=openid profile email
